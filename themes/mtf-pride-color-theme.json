  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9890A8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.instanceof",
        "keyword.operator.void",
        "keyword.operator.of",
        "keyword.operator.in"
      ],
      "settings": {
        "foreground": "#D1568C"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#D1568C"
      }
    },
    {
      "scope": [
        "constant",
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#C47A20"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#3B3252"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "variable.other.assignment"
      ],
      "settings": {
        "foreground": "#3B3252",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#D1568C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#1A8FB5"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#7C4DBA"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#D1568C"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#1A8FB5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#9E5580"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#4A80B0"
      }
    },
    {
      "scope": [
        "punctuation.definition.template-expression.begin",
        "punctuation.definition.template-expression.end"
      ],
      "settings": {
        "foreground": "#D1568C"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#4A80B0"
      }
    },
    {
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.block",
        "punctuation.definition.parameters",
        "punctuation.definition.arguments",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#7E7694"
      }
    },
    {
      "scope": [
        "entity.name.module",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#7C4DBA"
      }
    },
    {
      "scope": [
        "support.module",
        "support.node",
        "support.other.module"
      ],
      "settings": {
        "foreground": "#7C4DBA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function.decorator",
        "punctuation.definition.decorator"
      ],
      "settings": {
        "foreground": "#C47A20"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#1A8FB5"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.id",
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#1A8FB5"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
        "support.type.vendored.property-name"
      ],
      "settings": {
        "foreground": "#4A80B0"
      }
    },
    {
      "scope": [
        "support.constant.property-value.css",
        "support.constant.font-name",
        "constant.other.color.rgb-value"
      ],
      "settings": {
        "foreground": "#C47A20"
      }
    },
    {
      "scope": [
        "meta.tag.attributes",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#1A8FB5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.setext",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#1A8FB5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#D1568C",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#7C4DBA",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.underline"],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["markup.strikethrough"],
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": {
        "foreground": "#4A80B0"
      }
    },
    {
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#9E5580",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.list"],
      "settings": {
        "foreground": "#3B3252"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "punctuation.definition.inserted"
      ],
      "settings": {
        "foreground": "#1A8FB5"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "punctuation.definition.deleted"
      ],
      "settings": {
        "foreground": "#D1395E"
      }
    },
    {
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "settings": {
        "foreground": "#7C4DBA"
      }
    },
    {
      "scope": ["meta.diff.header"],
      "settings": {
        "foreground": "#7C4DBA"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#D1395E"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#C47A20",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticTokenColors": {
    "type": "#7C4DBA",
    "class": "#7C4DBA",
    "interface": "#7C4DBA",
    "struct": "#7C4DBA",
    "enum": "#7C4DBA",
    "enumMember": "#C47A20",
    "typeParameter": "#7C4DBA",
    "function": "#1A8FB5",
    "method": "#1A8FB5",
    "macro": "#D1568C",
    "variable": "#3B3252",
    "parameter": { "foreground": "#3B3252", "fontStyle": "italic" },
    "property": "#4A80B0",
    "namespace": "#7C4DBA",
    "keyword": "#D1568C",
    "string": "#9E5580",
    "number": "#C47A20",
    "regexp": "#4A80B0",
    "operator": "#4A80B0",
    "comment": { "foreground": "#9890A8", "fontStyle": "italic" },
    "decorator": "#C47A20"
  }
}
